{
  "ConnectionStrings": {
    //Server tähendab andmebaasi serveri aadressi, mis võib olla kohalik (localdb) või kaugserveris.
    //database tähendab andmebaasi nime, mida soovite kasutada.
    //Trusted_Connection=True tähendab, et ühendus kasutab Windowsi autentimist ja kasutaja peab olema õigustega Windowsi kasutaja.
    //MultipleActiveResultSets=true on lihtsalt saad ühe ja sama ühenduse kaudu teha mitut asja korraga
    "UniversityContext": "Server=(localdb)\\mssqllocaldb;Database=UniversityDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Datebase.Command" : "Information"
    }
  },
  "AllowedHosts": "*"
}
