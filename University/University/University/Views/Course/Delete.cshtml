@model University.ViewModel.CourseVM.CourseDeleteViewModel



@{
    ViewData["Title"] = "Course Delete";
}


<h2>Student Delete</h2>
<div>
    <h4>Student</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.CourseId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.CourseId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Credits)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentId)
        </dd>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DepartmentId)
        </dd>
        <dd class="col-sm-10">
            <table class="table">
                <tr>
                    <th>Course Title</th>
                    <th>Grade</th>
            
            </table>
        </dd>
    </dl>
</div>
    <hr />

    <form asp-action="DeletePost" method="post">
        <input type="hidden" name="id" value="@Model.CourseId" />

        <input type="submit"
               value="Delete"
               class="btn btn-danger" />

        <a asp-action="Index"
           asp-controller="Course"
           class="btn btn-success">
            Back to List
        </a>
    </form>